          <h2 className="text-sm font-semibold text-white drop-shadow">{channel.name}</h2>
          <div className="flex items-center gap-2 text-xs text-white/70">
            <span className="flex items-center gap-1">
              <span className="w-1.5 h-1.5 bg-red-500 rounded-full animate-pulse"></span>
              Live
            </span>
            <span>•</span>
            <span>{channel.country}</span>
          </div>
        </div>
      </div>

      {/* Custom Overlay Controls */}
      <div className="absolute bottom-16 left-4 right-4 z-10 flex items-center justify-between pointer-events-none">
        
        {/* Left side controls */}
        <div className="flex items-center gap-2 pointer-events-auto">
          <div className="flex items-center gap-2 bg-black/60 backdrop-blur text-white px-3 py-2 rounded-full shadow-lg border border-white/10 group">
            <button onClick={toggleMute} className="hover:text-blue-400 transition" aria-label="Toggle Mute" title="Mute">
              {getVolumeIcon()}
            </button>
            <input 
              type="range" 
              min="0" 
              max="1" 
              step="0.05" 
              value={muted ? 0 : volume} 
              onChange={handleVolumeChange} 
              className="w-0 sm:w-20 lg:w-24 opacity-0 sm:opacity-100 sm:group-hover:w-20 group-hover:opacity-100 group-hover:w-20 lg:group-hover:w-24 transition-all duration-300 accent-blue-500 cursor-pointer"
            />
          </div>
        </div>

        {/* Right side controls */}
        <div className="flex items-center gap-2 pointer-events-auto">
          <button onClick={() => handleSeek(-10)} className="bg-black/60 backdrop-blur text-white p-2 rounded-full hover:bg-black/80 transition shadow-lg border border-white/10" aria-label="Rewind 10 seconds" title="Rewind 10s">
             <Rewind className="w-4 h-4 sm:w-5 sm:h-5" />
          </button>
          <button onClick={() => handleSeek(10)} className="bg-black/60 backdrop-blur text-white p-2 rounded-full hover:bg-black/80 transition shadow-lg border border-white/10" aria-label="Fast forward 10 seconds" title="Forward 10s">
             <FastForward className="w-4 h-4 sm:w-5 sm:h-5" />
          </button>
          <button onClick={togglePip} className="bg-black/60 backdrop-blur text-white p-2 rounded-full hover:bg-black/80 transition shadow-lg border border-white/10" aria-label="Toggle Picture in Picture" title="Picture in Picture">
             <PictureInPicture className="w-4 h-4 sm:w-5 sm:h-5" />
          </button>
          <button onClick={toggleFullscreen} className="bg-black/60 backdrop-blur text-white p-2 rounded-full hover:bg-black/80 transition shadow-lg border border-white/10" aria-label="Toggle Fullscreen" title="Fullscreen">
             <Maximize className="w-4 h-4 sm:w-5 sm:h-5" />
          </button>
        </div>
      </div>

      <div className="flex-1 w-full h-full bg-black">
        {/* @ts-ignore - ignore url type since ReactPlayer relies on it */}
        <ReactPlayer
          ref={playerRef}
          {...({
            url: channel.url,
            width: "100%",
            height: "100%",
            playing: true,
            muted: muted,
            volume: volume,
            controls: true,
            pip: pip,
            style: { width: '100%', height: '100%', objectFit: 'contain' }
          } as any)}
        />
      </div>
    </div>
  );
}